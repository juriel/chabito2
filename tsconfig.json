{
  "compilerOptions": {
    // 📁 Estructura
    "rootDir": ".",
    "outDir": "./dist",

    // ⚙️ Entorno Node
    "module": "nodenext",
    "target": "es2022",
    "lib": ["es2022"],
    "types": ["node"],

    // 📦 Output
    "sourceMap": false,
    "declaration": false,
    "declarationMap": false,

    // 🧠 Tipado estricto
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // 🔧 Compatibilidad moderna
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": ["**/*.ts", "**/*.d.ts"],
  "exclude": ["dist", "node_modules"]
}
